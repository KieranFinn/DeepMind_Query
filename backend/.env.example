# DeepMind_Query Backend Environment Variables

# ========== API Keys ==========
# LLM Provider API keys. The system routes based on model prefix:
# - MiniMax-* models use MINIMAX_API_KEY -> MiniMax API
# - claude-* models use ANTHROPIC_API_KEY -> Anthropic API

# MiniMax API key (for MiniMax-* models)
MINIMAX_API_KEY=your_minimax_api_key_here

# Anthropic API key (for claude-* models) - optional if only using MiniMax
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ========== Provider Selection ==========
# Default LLM provider: "minimax" or "anthropic"
LLM_PROVIDER=minimax

# ========== API Authentication ==========
# Optional: Set this to enable API key authentication
# If not set, API is open (for development)
API_KEY=your_api_key_here

# ========== Model Support ==========
# Supported models:
# - MiniMax-M2.7 (MiniMax API)
# - claude-sonnet-4-20250514, claude-opus-4-20250514, etc. (Anthropic API)
